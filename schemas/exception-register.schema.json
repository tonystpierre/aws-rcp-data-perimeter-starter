{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/exception-register.schema.json",
  "title": "RCP data perimeter exception register",
  "type": "object",
  "required": [
    "version",
    "exceptions"
  ],
  "additionalProperties": false,
  "properties": {
    "version": {
      "type": "string"
    },
    "exceptions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "status",
          "type",
          "owner",
          "approval_owner",
          "business_reason",
          "affected_service",
          "source",
          "target_resource_scope",
          "policy_layers",
          "environment",
          "scope",
          "related_policy_sids",
          "created_at",
          "review_by",
          "expires_at",
          "evidence",
          "cloudtrail_evidence",
          "access_analyzer_evidence",
          "rollback_plan"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "enum": [
              "proposed",
              "approved",
              "active",
              "expired",
              "revoked"
            ]
          },
          "type": {
            "type": "string",
            "enum": [
              "vendor-principal",
              "aws-service-integration",
              "break-glass"
            ]
          },
          "owner": {
            "type": "string",
            "minLength": 1
          },
          "approval_owner": {
            "type": "string",
            "minLength": 1
          },
          "business_reason": {
            "type": "string",
            "minLength": 1
          },
          "affected_service": {
            "type": "string",
            "minLength": 1
          },
          "source": {
            "type": "object",
            "minProperties": 1
          },
          "target_resource_scope": {
            "type": "object",
            "minProperties": 1
          },
          "policy_layers": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "enum": [
                "scp",
                "rcp",
                "resource-policy",
                "identity-policy",
                "endpoint-policy",
                "other"
              ]
            }
          },
          "environment": {
            "type": "string",
            "minLength": 1
          },
          "scope": {
            "type": "object",
            "minProperties": 1
          },
          "related_policy_sids": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "created_at": {
            "type": "string",
            "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
          },
          "review_by": {
            "type": "string",
            "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
          },
          "expires_at": {
            "type": "string",
            "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
          },
          "evidence": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "cloudtrail_evidence": {
            "type": "object",
            "minProperties": 1
          },
          "access_analyzer_evidence": {
            "type": "object",
            "minProperties": 1
          },
          "rollback_plan": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
