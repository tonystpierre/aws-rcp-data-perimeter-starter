{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/exception-register.schema.json",
  "title": "RCP data perimeter exception register",
  "type": "object",
  "required": [
    "version",
    "exceptions"
  ],
  "additionalProperties": false,
  "properties": {
    "version": {
      "type": "string"
    },
    "exceptions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "status",
          "type",
          "owner",
          "business_reason",
          "scope",
          "related_policy_sids",
          "review_by",
          "evidence",
          "rollback_plan"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "enum": [
              "proposed",
              "approved",
              "expired",
              "rejected"
            ]
          },
          "type": {
            "type": "string",
            "enum": [
              "vendor-principal",
              "aws-service-integration",
              "break-glass"
            ]
          },
          "owner": {
            "type": "string",
            "minLength": 1
          },
          "business_reason": {
            "type": "string",
            "minLength": 1
          },
          "scope": {
            "type": "object",
            "minProperties": 1
          },
          "related_policy_sids": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "review_by": {
            "type": "string",
            "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
          },
          "evidence": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "rollback_plan": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}

